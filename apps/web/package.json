    "@types/mdx": "latest",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@1chooo/eslint-config": "workspace:^",
    "@1chooo/typescript-config": "workspace:*",
