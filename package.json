{
  "name": "embed-card-monorepo",
  "version": "0.1.5",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --filter=web",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "publish:embed-card": "cd packages/embed-card && npm login && npm publish --access public"
  },
  "devDependencies": {
    "@1chooo/eslint-config": "workspace:*",
    "@1chooo/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
