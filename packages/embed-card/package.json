{
  "name": "embed-card",
  "version": "0.1.3",
  "type": "module",
  "private": false,
  "description": "Framework-friendly embed cards for YouTube, X, Reddit, Google Maps, Vimeo, and custom providers.",
  "keywords": [
    "embed",
    "react",
    "web-component",
    "youtube",
    "twitter",
    "reddit",
    "vimeo",
    "google-maps"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "homepage": "https://1chooo.com/embed-card",
  "bugs": {
    "url": "https://github.com/1chooo/embed-card/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1chooo/embed-card.git",
    "directory": "packages/embed-card"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manual": {
      "types": "./dist/manual.d.ts",
      "import": "./dist/manual.js"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./dist/web-component.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.2.10",
    "@1chooo/eslint-config": "workspace:*",
    "@1chooo/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
