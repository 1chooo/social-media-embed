{
  "name": "embed-card",
  "version": "0.3.0",
  "type": "module",
  "private": false,
  "description": "Framework-friendly embed cards for YouTube, X, Instagram, Reddit, Google Maps, Vimeo, TikTok, and custom providers.",
  "license": "MIT",
  "author": "Lin Hugo (@1chooo)",
  "authorUrl": "https://1chooo.com",
  "authorEmail": "1chooo@gmail.com",
  "authorWebsite": "https://1chooo.com",
  "authorTwitter": "https://x.com/1chooo___",
  "authorGitHub": "https://github.com/1chooo",
  "authorLinkedIn": "https://linkedin.com/in/1chooo",
  "keywords": [
    "embed",
    "react",
    "web-component",
    "youtube",
    "twitter",
    "reddit",
    "vimeo",
    "google-maps",
    "instagram",
    "tiktok"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "homepage": "https://1chooo.com/embed-card",
  "bugs": {
    "url": "https://github.com/1chooo/embed-card/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1chooo/embed-card.git",
    "directory": "packages/embed-card"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./manual": {
      "types": "./dist/manual.d.ts",
      "import": "./dist/manual.js"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./dist/web-component.js"
    },
    "./next-themes": {
      "types": "./dist/next-themes.d.ts",
      "import": "./dist/next-themes.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "next-themes": "^0.3.0 || ^0.4.0",
    "react": "^18.3.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next-themes": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@1chooo/eslint-config": "workspace:*",
    "@1chooo/typescript-config": "workspace:*",
    "@types/react": "^19.2.10",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "next-themes": "^0.4.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
